{
  "expo": {
    "name": "Rezo Haptic",
    "slug": "rezo-haptic",
    "scheme": "rezohaptic",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "jsEngine": "jsc",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0D10"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Rezo uses Bluetooth to connect to your haptic metronome device."
      }
    },
    "android": {
      "package": "com.razdo.rezohaptic",
      "permissions": [
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0D10"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "react-native-ble-plx"
    ],
    "extra": {
      "eas": {
        "projectId": "3bc8d984-2b83-4a17-aee5-b639e9267cd8"
      }
    },
    "owner": "razdo.27"
  }
}
